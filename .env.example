# Copy this file to .env (project root) and fill in your own values.
# .env is already in .gitignore -- never commit the real one.

# Google Cloud OAuth 2.0 Client, "Desktop app" type -- used for the
# "Sign in with Google" button on the Restore tab.
# Create one at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
